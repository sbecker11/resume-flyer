{
  "name": "color-palette-utils-ts",
  "version": "1.0.0",
  "description": "TypeScript types and color utilities for Color Palette Maker exported palette JSON",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "vitest.config.ts",
    "tsconfig.json",
    "README-ts.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "color",
    "palette",
    "hex",
    "contrast",
    "typescript"
  ],
  "license": "MIT"
}
