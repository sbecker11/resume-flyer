# Backend (Express) server port; also used as Vite proxy target when VITE_API_PORT is unset. 3001 avoids conflict with 3000.
EXPRESS_PORT=3001

# Vite dev server port. 5174 avoids conflict with apps on 5173; change for more instances.
VITE_DEV_PORT=5174

# Target for Vite proxy to backend. Defaults to EXPRESS_PORT; set when running frontend dev alone.
# VITE_API_PORT=3001

# Figma API token: used by figma sync tooling (e.g. npm run figma-sync, npm run watch-figma) to
# authenticate with the Figma API when syncing design tokens or config to a Figma file. Get a
# personal access token from Figma → Account settings → Personal access tokens. Replace with your token.
FIGMA_TOKEN=users-figma-token
