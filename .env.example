# Copy to .env and fill in secrets (API keys, tokens). Only .env.example is committed; .env is gitignored.

# Backend (Express) server port; also used as Vite proxy target when VITE_API_PORT is unset. 3001 avoids conflict with 3000.
EXPRESS_PORT=3001

# Vite dev server port. 5174 avoids conflict with apps on 5173; change for more instances.
VITE_DEV_PORT=5174

# Target for Vite proxy to backend. Defaults to EXPRESS_PORT; set when running frontend dev alone.
# VITE_API_PORT=3001

# Optional: Parsed resumes directory (default: ./parsed_resumes). Override for tests or custom paths.
# PARSED_RESUMES_DIR=./parsed_resumes

# S3 palette catalog (recommended for production). Documented in color-palette-utils-ts/README-ts.md; tests use this URL shape:
#   https://sbecker11-color-palette-images.s3.us-west-1.amazonaws.com/metadata/color_palettes.jsonl
# Decomposition (bucket / region / object key) — same as palettesCatalog.test.ts S3_URL:
#   S3_BUCKET=sbecker11-color-palette-images
#   S3_REGION=us-west-1
#   S3_COLOR_PALETTES_OBJECT_KEY=metadata/color_palettes.jsonl
#
# Option A — full URL (matches CPM-ts S3_COLOR_PALETTES_JSON_URL):
# S3_COLOR_PALETTES_JSON_URL=https://sbecker11-color-palette-images.s3.us-west-1.amazonaws.com/metadata/color_palettes.jsonl
#
# Option B — bucket + region + key (resume-flock builds the same URL; omit S3_COLOR_PALETTES_JSON_URL):
# S3_BUCKET=sbecker11-color-palette-images
# S3_REGION=us-west-1
# S3_COLOR_PALETTES_OBJECT_KEY=metadata/color_palettes.jsonl
#
# Vite exposes S3_* via envPrefix in vite.config.js. Fetch on startup/hard refresh (no-store); localStorage holds readonly cache snapshot on success.
