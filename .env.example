# Copy to .env and fill in secrets (API keys, tokens). Only .env.example is committed; .env is gitignored.

# Backend (Express) server port; also used as Vite proxy target when VITE_API_PORT is unset. 3001 avoids conflict with 3000.
EXPRESS_PORT=3001

# Vite dev server port. 5174 avoids conflict with apps on 5173; change for more instances.
VITE_DEV_PORT=5174

# Target for Vite proxy to backend. Uses EXPRESS_PORT unless VITE_API_PORT is set; set when running frontend dev alone.
# VITE_API_PORT=3001

# Parsed resumes directory used by the server.
PARSED_RESUMES_DIR=./parsed_resumes

# Path to the resume-parser project. The server/script uses <path>/venv/bin/python3.
RESUME_PARSER_PROJECT_PATH=../resume-parser

# S3 catalog endpoint and region for palette loading.
S3_COLOR_PALETTES_JSON_URL=https://sbecker11-color-palette-images.s3.us-west-1.amazonaws.com/metadata/color_palettes.jsonl
AWS_REGION=us-west-1

# OpenAI API key for skill definition lookups (/api/skills/:slug/info)
OPENAI_API_KEY=
