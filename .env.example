# Copy to .env and fill in secrets (API keys, tokens). Only .env.example is committed; .env is gitignored.

# Backend (Express) server port; also used as Vite proxy target when VITE_API_PORT is unset. 3001 avoids conflict with 3000.
EXPRESS_PORT=3001

# Vite dev server port. 5174 avoids conflict with apps on 5173; change for more instances.
VITE_DEV_PORT=5174

# Target for Vite proxy to backend. Defaults to EXPRESS_PORT; set when running frontend dev alone.
# VITE_API_PORT=3001

# Optional: Python resume parser (for npm run parse-resume). Default: ../../workspace-resume/resume-parser.
# Set in .env or export in shell if the parser repo is elsewhere.
# RESUME_PARSER_PATH=/path/to/resume-parser

# Optional: External HTML renderer for the Render button. Node script path; receives resume folder path as first arg.
# Script must write output to <resume-folder>/rendered.html
# RESUME_HTML_RENDERER_SCRIPT=/path/to/render-resume-html.mjs

# Secrets — set real values in .env only; never commit .env.
# AI_API_KEY=your-ai-api-key
