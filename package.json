{
  "name": "resume-flyer",
  "version": "0.9.0",
  "description": "Dark, chaotic, and deep. This provides a novel way of exploring a resume. The resume is defined as a collection of jobs, skills, and categories parsed from a DOCX or PDF formatted resume file by the resume-parser utility.",
  "keywords": [
    "javascript",
    "vue",
    "vite",
    "node",
    "resume",
    "visualization",
    "d3",
    "parallax",
    "generative-ai",
    "design-systems",
    "reactive"
  ],
  "homepage": "https://github.com/sbecker11/resume-flyer#readme",
  "bugs": {
    "url": "https://github.com/sbecker11/resume-flyer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbecker11/resume-flyer.git"
  },
  "license": "MIT",
  "author": "Shawn Becker",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "npm run kill-listeners && node scripts/start-dev.mjs",
    "dev:concurrent": "npm run kill-listeners && concurrently \"npm:node-server\" \"vite\" \"npm:open-chrome\"",
    "start": "npm run kill-listeners && concurrently \"npm run node-server\" \"npm run open-chrome\"",
    "node-server": "nodemon server.mjs",
    "open-chrome": "node scripts/open-app.mjs",
    "preview": "vite preview",
    "build": "vite build",
    "kill-listeners": "pkill -f 'node server.mjs' && pkill -f 'nodemon' && pkill -f 'vite' || true",
    "clean": "npm run kill-listeners && rm -rf node_modules dist .vite npm-debug.log* && npm cache clean --force",
    "test": "vitest run --config vitest.config.js && (cd palette-utils-ts && npm test)",
    "test:watch": "vitest --config vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage && (cd palette-utils-ts && npm run test:coverage)",
    "parse-resume": "node scripts/run-parse-resume.mjs",
    "compliance": "node scripts/run-compliance-scan.mjs",
    "sync-color-palette-utils-ts": "node scripts/sync-color-palette-utils-ts.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@notionhq/client": "^2.2.15",
    "@vueuse/core": "^13.4.0",
    "@xstate/vue": "^3.0.0",
    "airtable": "^0.12.2",
    "color-palette-utils-ts": "file:./palette-utils-ts",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "dayjs": "^1.11.10",
    "dotenv": "^17.1.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "googleapis": "^140.0.1",
    "log4js": "^6.9.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.86.1",
    "pinia": "^2.1.7",
    "puppeteer": "^22.13.1",
    "sanitize-filename": "^1.6.3",
    "xstate": "^5.16.0"
  },
  "devDependencies": {
    "@types/multer": "^1.4.11",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.2",
    "happy-dom": "^20.8.3",
    "nodemon": "^3.1.10",
    "open-cli": "^8.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "vue": "^3.4.29"
  }
}
