{
  "name": "resume-flock",
  "version": "0.9.0",
  "description": "Dark, chaotic, and deep. This app creates an animated flock of postcards from a resume. The resume is defined as a job.xlsx file where each row describes a job, with start/end dates and a descriptive paragraph that includes links to related skills. Each job is visualized as a large business card. Each skill is visualized as smaller chips. The flock is rendered in the left panel with motion parallax as the mouse is moved around. Skill chips fly above the darker business cards. The right panel shows a readable version of selected jobs and skills.",
  "keywords": [
    "javascript",
    "vue",
    "vite",
    "node",
    "resume",
    "visualization",
    "d3",
    "parallax",
    "generative-ai",
    "figma",
    "design-systems",
    "reactive"
  ],
  "homepage": "https://github.com/sbecker11/resume-flock#readme",
  "bugs": {
    "url": "https://github.com/sbecker11/resume-flock/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sbecker11/resume-flock.git"
  },
  "license": "MIT",
  "author": "Shawn Becker",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "npm run kill-listeners && node scripts/start-dev.mjs",
    "dev:concurrent": "npm run kill-listeners && concurrently \"npm:node-server\" \"vite\" \"npm:open-chrome\"",
    "preview": "vite preview",
    "build": "vite build",
    "start": "npm run kill-listeners && concurrently \"npm run node-server\" \"npm run open-chrome\"",
    "node-server": "nodemon server.mjs",
    "open-chrome": "node scripts/open-app.mjs",
    "kill-listeners": "pkill -f 'node server.mjs' && pkill -f 'nodemon' && pkill -f 'vite' || true",
    "clean": "npm run kill-listeners && rm -rf node_modules dist .vite npm-debug.log* && npm cache clean --force",
    "extract-tokens": "node scripts/extract-design-tokens.mjs",
    "figma-sync": "node scripts/figma-sync.mjs",
    "watch-figma": "node scripts/watch-and-sync.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@notionhq/client": "^2.2.15",
    "@vueuse/core": "^13.4.0",
    "@xstate/vue": "^3.0.0",
    "airtable": "^0.12.2",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "dayjs": "^1.11.10",
    "dotenv": "^17.1.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "googleapis": "^140.0.1",
    "log4js": "^6.9.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.86.1",
    "pinia": "^2.1.7",
    "puppeteer": "^22.13.1",
    "sanitize-filename": "^1.6.3",
    "xstate": "^5.16.0"
  },
  "devDependencies": {
    "@types/multer": "^1.4.11",
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "open-cli": "^8.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vue": "^3.4.29"
  }
}
